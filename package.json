{
  "name": "@glenn123/pantry-test-oidc",
  "version": "0.3.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "bun-git-hooks": "^0.3.1"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
